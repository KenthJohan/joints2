{
    "id": "app1",
    "type": "application",
    "value": {
        "language": "c",
        "use": [
            "flecs",
			"ecsx",
			"EgSpatials",
			"EgSpatialsSystems",
			"EgShapes",
			"EgWindows",
			"EgWindowsSdl",
			"EgWindowsSdlGl",
			"EgCameras",
			"EgButtons",
			"egmath",
			"box2d",
			"draw"
        ],
        "public": false
    },
	"lang.c": {
		"c-standard": "gnu99",
		"defines": [
			"_FORTIFY_SOURCE=2",
			"GL_GLEXT_PROTOTYPES"
		],
		"lib": [
			"EgCameras",
			"EgShapes",
			"EgSpatials",
			"EgSpatialsSystems",
			"EgWindows",
			"EgWindowsSdl",
			"EgWindowsSdlGl",
			"EgButtons",
			"EgFs",
			"EgBase",
			"EgGlslang",
			"egmisc",
			"egmath",
			"ecsx",
			"box2d",
			"flecs",
			"draw",
			"SDL3",
			"GL",
			"stdc++",
			"m"
		],
		"cflags": [
			"-Werror",
			"-Wall",
			"-Wextra",
			"-Wno-error=unused-local-typedefs",
			"-Wno-error=unused-const-variable=",
			"-Wno-error=unused-variable",
			"-Wno-error=unused-function",
			"-ftrapv",
			"-Werror=format-security",
			"-Wl,-z,defs",
			"-fstack-clash-protection",
			"-fstack-protector-strong",
			"-fstack-protector",
			"-fstack-protector-all",
			"-grecord-gcc-switches",
			"-pipe",
			"-Werror=implicit-function-declaration",
			"-Wl,-z,now",
			"-Wl,-z,relro",
			"-Wwrite-strings"
		]
	}
}
