export const SCANCODE_PAGEUP = i32: 75
export const SCANCODE_DELETE = i32: 76
export const SCANCODE_END = i32: 77
export const SCANCODE_PAGEDOWN = i32: 78
export const SCANCODE_RIGHT = i32: 79
export const SCANCODE_LEFT = i32: 80
export const SCANCODE_DOWN = i32: 81
export const SCANCODE_UP = i32: 82
export const SCANCODE_KP_DIVIDE = i32: 84
export const SCANCODE_KP_MULTIPLY = i32: 85
export const SCANCODE_KP_MINUS = i32: 86
