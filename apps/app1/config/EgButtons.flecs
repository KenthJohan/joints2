export const SCANCODE_2 = i32: 31
export const SCANCODE_3 = i32: 32
export const SCANCODE_4 = i32: 33
export const SCANCODE_5 = i32: 34
export const SCANCODE_6 = i32: 35
export const SCANCODE_7 = i32: 36
export const SCANCODE_8 = i32: 37
export const SCANCODE_9 = i32: 38
export const SCANCODE_0 = i32: 39
export const SCANCODE_RETURN = i32: 40
export const SCANCODE_ESCAPE = i32: 41
export const SCANCODE_BACKSPACE = i32: 42
export const SCANCODE_TAB = i32: 43
